@model SmartBike_MVC.Models.ChatbotAdminViewModel
@{
    Layout = "_AdminLayout";
}

<h1 class="sb-admin-page-title mb-1">Gestión del chatbot</h1>
<p class="sb-admin-texto-suave mb-4">Administra las preguntas sugeridas de SmartBot.</p>

@if (Model.ErrorApi != null)
{
    <div class="alert alert-warning">@Model.ErrorApi</div>
}


<!-- ==================== PREGUNTAS SUGERIDAS ==================== -->
<div class="sb-admin-panel">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h5 fw-bold mb-0">Preguntas sugeridas del chatbot</h2>
        <button type="button" class="btn sb-admin-btn-green"
                aria-label="Agregar nueva pregunta sugerida"
                data-bs-toggle="modal" data-bs-target="#modalNueva">
            <i class="fa-solid fa-plus me-1" aria-hidden="true"></i> Nueva
        </button>
    </div>

    @if (!Model.PreguntasFrecuentes.Any())
    {
        <p class="sb-admin-texto-suave mb-0">Aún no hay preguntas sugeridas registradas.</p>
    }
    else
    {
        @foreach (var faq in Model.PreguntasFrecuentes)
        {
            <div class="sb-admin-row">
                <div>
                    <div class="sb-admin-row-title">
                        @faq.TextoPregunta
                        @if (!faq.Activo)
                        {
                            <span class="badge bg-secondary ms-2">Inactiva</span>
                        }
                    </div>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="sb-admin-icon-btn"
                            title="Editar"
                            aria-label="Editar pregunta sugerida"
                            data-bs-toggle="modal"
                            data-bs-target="#modalEditar"
                            data-id="@faq.PreguntaId"
                            data-texto="@faq.TextoPregunta"
                            data-orden="@faq.Orden"
                            data-activo="@faq.Activo.ToString().ToLower()">
                        <i class="fa-solid fa-pencil" aria-hidden="true"></i>
                    </button>
                    <form asp-action="EliminarPregunta" method="post" class="m-0"
                          onsubmit="return confirm('¿Eliminar esta pregunta sugerida?');">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@faq.PreguntaId" />
                        <button type="submit" class="sb-admin-icon-btn sb-admin-icon-danger" title="Eliminar"
                                aria-label="Eliminar pregunta sugerida">
                            <i class="fa-regular fa-trash-can" aria-hidden="true"></i>
                        </button>
                    </form>
                </div>
            </div>
        }
    }
</div>

<!-- ==================== MODAL: NUEVA PREGUNTA ==================== -->
<div class="modal fade" id="modalNueva" tabindex="-1" aria-labelledby="tituloModalNueva" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="CrearPregunta" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <div class="modal-header">
                <h2 class="h5 modal-title" id="tituloModalNueva">Nueva pregunta sugerida</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label" for="nueva-texto">Pregunta</label>
                    <input name="TextoPregunta" id="nueva-texto" class="form-control" maxlength="200" required />
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label" for="nueva-orden">Orden</label>
                        <input name="Orden" id="nueva-orden" type="number" class="form-control" value="0" />
                    </div>
                    <div class="col-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input name="Activo" id="nueva-activo" class="form-check-input" type="checkbox" value="true" checked />
                            <input name="Activo" type="hidden" value="false" />
                            <label class="form-check-label" for="nueva-activo">Activa</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn sb-admin-btn-green">Guardar</button>
            </div>
        </form>
    </div>
</div>

<!-- ==================== MODAL: EDITAR PREGUNTA ==================== -->
<div class="modal fade" id="modalEditar" tabindex="-1" aria-labelledby="tituloModalEditar" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="EditarPregunta" method="post" class="modal-content">
            @Html.AntiForgeryToken()
            <input type="hidden" name="PreguntaId" id="edit-id" />
            <div class="modal-header">
                <h2 class="h5 modal-title" id="tituloModalEditar">Editar pregunta sugerida</h2>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label class="form-label" for="edit-texto">Pregunta</label>
                    <input name="TextoPregunta" id="edit-texto" class="form-control" maxlength="200" required />
                </div>
                <div class="row">
                    <div class="col-6 mb-3">
                        <label class="form-label" for="edit-orden">Orden</label>
                        <input name="Orden" id="edit-orden" type="number" class="form-control" />
                    </div>
                    <div class="col-6 mb-3 d-flex align-items-end">
                        <div class="form-check">
                            <input name="Activo" id="edit-activo" class="form-check-input" type="checkbox" value="true" />
                            <input name="Activo" type="hidden" value="false" />
                            <label class="form-check-label" for="edit-activo">Activa</label>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="submit" class="btn sb-admin-btn-green">Actualizar</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        // Rellena el modal de edición con los datos de la fila seleccionada
        const modalEditar = document.getElementById('modalEditar');
        modalEditar.addEventListener('show.bs.modal', function (event) {
            const btn = event.relatedTarget;
            document.getElementById('edit-id').value = btn.dataset.id;
            document.getElementById('edit-texto').value = btn.dataset.texto;
            document.getElementById('edit-orden').value = btn.dataset.orden;
            document.getElementById('edit-activo').checked = (btn.dataset.activo === 'true');
        });
    </script>
}