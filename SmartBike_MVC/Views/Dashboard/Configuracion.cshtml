@{
    ViewData["Title"] = "Configuración";
    ViewData["Active"] = "Configuracion";
    Layout = "_DashboardLayout";
}

<h2 class="sb-dash-title">Configuración</h2>
<p class="sb-dash-subtitle">Personaliza tu experiencia en SmartBike UTN</p>

<div class="sb-profile-card mt-3">
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="notif" checked>
        <label class="form-check-label" for="notif">Notificaciones de recordatorio diario</label>
    </div>
    <div class="form-check form-switch mb-3">
        <input class="form-check-input" type="checkbox" id="tema">
        <label class="form-check-label" for="tema">Modo oscuro</label>
    </div>
    <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" id="ubicacion" checked>
        <label class="form-check-label" for="ubicacion">Compartir ubicación en el campus</label>
    </div>
</div>