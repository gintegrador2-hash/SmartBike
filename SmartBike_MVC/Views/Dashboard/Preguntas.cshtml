@model SmartBike_MVC.Models.PreguntasViewModel
@{
    ViewData["Title"] = "Preguntas Frecuentes";
    ViewData["Active"] = "Preguntas";
    Layout = "_DashboardLayout";
}

<style>
    /* --- ANIMACIÓN DE PENSANDO --- */
    .typing-indicator {
        display: inline-flex;
        align-items: center;
        height: 24px;
        padding: 0 5px;
    }

    .typing-indicator span {
        display: inline-block;
        width: 8px;
        height: 8px;
        background-color: #90949c;
        border-radius: 50%;
        margin: 0 2px;
        animation: typing 1.4s infinite both;
    }

    .typing-indicator span:nth-child(1) { animation-delay: 0s; }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }

    @@keyframes typing {
        0%, 80%, 100% { transform: translateY(0); }
        40% { transform: translateY(-5px); }
    }
</style>

<h2 class="sb-dash-title">Preguntas Frecuentes</h2>
<p class="sb-dash-subtitle">Habla con SmartBot, nuestro asistente virtual</p>

<div class="sb-chip-row mt-3">
    @foreach (var pregunta in Model.PreguntasSugeridas)
    {
        <button type="button" class="sb-chip" onclick="enviarPreguntaSugerida(this)">@pregunta</button>
    }
</div>

<div class="sb-chat-box mt-3" id="sbChatBox">
    @foreach (var msg in Model.Mensajes)
    {
        <div class="sb-chat-msg @(msg.EsBot ? "sb-chat-bot" : "sb-chat-user")">
            @if (msg.EsBot)
            {
                <div class="sb-widget-icon sb-chat-avatar"><i class="fa-solid fa-robot"></i></div>
            }
            <div class="sb-chat-bubble">@msg.Texto</div>
        </div>
    }
</div>

<form class="sb-chat-input-row" id="sbChatForm">
    <input type="text" id="sbChatInput" class="form-control" placeholder="Escribe tu pregunta..." autocomplete="off" />
    <button type="submit" class="btn sb-btn-solid sb-chat-send"><i class="fa-solid fa-paper-plane"></i></button>
</form>

@section Scripts {
    <script>
        // Función clásica para agregar mensajes normales
        function agregarMensaje(texto, esUsuario) {
            const box = document.getElementById('sbChatBox');
            const div = document.createElement('div');
            div.className = 'sb-chat-msg ' + (esUsuario ? 'sb-chat-user' : 'sb-chat-bot');
            div.innerHTML = (esUsuario ? '' : '<div class="sb-widget-icon sb-chat-avatar"><i class="fa-solid fa-robot"></i></div>')
                + '<div class="sb-chat-bubble">' + texto + '</div>';
            box.appendChild(div);
            box.scrollTop = box.scrollHeight;
        }

        // Efecto visual de escribir letra por letra
        function efectoMaquinaDeEscribir(texto, elementoDestino, velocidad = 20) {
            let i = 0;
            elementoDestino.innerHTML = "";
            
            function escribir() {
                if (i < texto.length) {
                    if(texto.charAt(i) === '\n') {
                        elementoDestino.innerHTML += '<br>';
                    } else {
                        elementoDestino.innerHTML += texto.charAt(i);
                    }
                    i++;
                    setTimeout(escribir, velocidad);
                    // Hacer scroll mientras escribe
                    const box = document.getElementById('sbChatBox');
                    box.scrollTop = box.scrollHeight;
                }
            }
            escribir();
        }

        async function procesarPregunta(texto) {
            const box = document.getElementById('sbChatBox');
            
            // 1. Mostrar pregunta del usuario
            agregarMensaje(texto, true);
            
            // 2. Mostrar burbuja de "pensando..."
            const idPensando = "pensando-" + Date.now();
            const divPensando = document.createElement('div');
            divPensando.id = idPensando;
            divPensando.className = 'sb-chat-msg sb-chat-bot';
            divPensando.innerHTML = '<div class="sb-widget-icon sb-chat-avatar"><i class="fa-solid fa-robot"></i></div>'
                + '<div class="sb-chat-bubble"><div class="typing-indicator"><span></span><span></span><span></span></div></div>';
            box.appendChild(divPensando);
            box.scrollTop = box.scrollHeight;
            
            try {
                // 3. Llamar a nuestro controlador C#
                const respuesta = await fetch('/Dashboard/EnviarMensajeN8N', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(texto)
                });

                const datos = await respuesta.json();
                
                // 4. Eliminar la burbuja de "pensando..."
                document.getElementById(idPensando).remove();
                
                // 5. Mostrar la respuesta con el efecto de escritura
                if(datos && datos.respuesta) {
                    const idRespuesta = "respuesta-" + Date.now();
                    const divRespuesta = document.createElement('div');
                    divRespuesta.className = 'sb-chat-msg sb-chat-bot';
                    divRespuesta.innerHTML = '<div class="sb-widget-icon sb-chat-avatar"><i class="fa-solid fa-robot"></i></div>'
                        + '<div class="sb-chat-bubble" id="' + idRespuesta + '"></div>';
                    
                    box.appendChild(divRespuesta);
                    
                    // Lanzar la magia
                    efectoMaquinaDeEscribir(datos.respuesta, document.getElementById(idRespuesta));
                } else {
                    agregarMensaje("n8n recibió el mensaje, pero no devolvió el formato JSON correcto.", false);
                }
                
            } catch (error) {
                console.error("Error:", error);
                document.getElementById(idPensando)?.remove();
                agregarMensaje("Hubo un problema de conexión con el servidor.", false);
            }
        }

        function enviarPreguntaSugerida(btn) {
            procesarPregunta(btn.textContent);
        }

        document.getElementById('sbChatForm').addEventListener('submit', function(e) {
            e.preventDefault();
            const input = document.getElementById('sbChatInput');
            const texto = input.value;
            
            if (!texto.trim()) return;
            
            procesarPregunta(texto);
            input.value = ''; // Limpiar el input
        });
    </script>
}