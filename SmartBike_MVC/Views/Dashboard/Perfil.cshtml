@model SmartBike_MVC.Models.PerfilViewModel
@{
    ViewData["Title"] = "Mi Perfil";
    ViewData["Active"] = "Perfil";
    Layout = "_DashboardLayout";
}

<h2 class="sb-dash-title">Mi Perfil</h2>

<div class="sb-profile-card mt-3">
    <div class="d-flex align-items-center">
        <div class="sb-profile-avatar">@Model.Iniciales</div>
        <div class="ms-3">
            <div class="sb-profile-name">@Model.Nombres @Model.Apellidos</div>
            <div class="sb-profile-meta">@Model.Carrera</div>
            <div class="sb-profile-meta">@Model.CorreoInstitucional</div>
        </div>
    </div>
    <hr />
    <a href="#" class="sb-profile-option"><i class="fa-regular fa-pen-to-square"></i> Editar perfil</a>
    <a href="#" class="sb-profile-option"><i class="fa-solid fa-lock"></i> Cambiar contraseña</a>
    <form asp-controller="Account" asp-action="Logout" method="post">
        <button type="submit" class="sb-profile-option sb-profile-danger">
            <i class="fa-solid fa-arrow-right-from-bracket"></i> Cerrar sesión
        </button>
    </form>
</div>