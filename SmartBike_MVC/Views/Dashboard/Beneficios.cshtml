@model List<SmartBike_MVC.Models.BeneficioViewModel>
@{
    ViewData["Title"] = "Beneficios";
    ViewData["Active"] = "Beneficios";
    Layout = "_DashboardLayout";
}

<h1 class="sb-dash-title h2">Beneficios</h1>
<p class="sb-dash-subtitle">Descubre por qué SmartBike es la mejor opción para tu movilidad</p>

<div class="row g-3 mt-1">
    @foreach (var beneficio in Model)
    {
        <div class="col-lg-6 col-md-6">
            <div class="sb-dato-card">
                <div class="sb-icon-circle @beneficio.IconoBg">
                    <i class="fa-solid @beneficio.Icono" aria-hidden="true"></i>
                </div>
                <h2 class="h6 fw-bold mt-3 mb-1">@beneficio.Titulo</h2>
                <p class="sb-admin-texto-suave mb-0">@beneficio.Descripcion</p>
            </div>
        </div>
    }
</div>