@model SmartBike_MVC.Models.RegisterViewModel
@{
    ViewData["Title"] = "Crear cuenta";
    Layout = "_AuthLayout";
}
<div class="sb-auth-brand">
    <div class="sb-widget-icon sb-auth-icon"><i class="fa-solid fa-bicycle" aria-hidden="true"></i></div>
    <div class="ms-2">
        <div class="sb-auth-brand-title">SmartBike</div>
        <div class="sb-auth-brand-subtitle">Universidad Técnica del Norte</div>
    </div>
</div>
<h3 class="sb-auth-heading">Crear cuenta</h3>
<p class="sb-auth-subheading">Regístrate con tu correo institucional</p>
<form asp-controller="Account" asp-action="Register" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>

    <div class="mb-3">
        <label asp-for="Cedula" class="form-label"></label>
        <input asp-for="Cedula" id="Cedula" class="form-control" placeholder="Ingrese sus 10 dígitos" />
        <span asp-validation-for="Cedula" class="text-danger"></span>

        <!-- Contenedor para el mensaje de error con Leyes de UX -->
        <div id="cedulaFeedback" class="invalid-feedback"></div>
    </div>

    <div class="row">
        <div class="col-6 mb-3">
            <label asp-for="Nombres" class="form-label"></label>
            <input asp-for="Nombres" class="form-control" />
            <span asp-validation-for="Nombres" class="text-danger"></span>
        </div>
        <div class="col-6 mb-3">
            <label asp-for="Apellidos" class="form-label"></label>
            <input asp-for="Apellidos" class="form-control" />
            <span asp-validation-for="Apellidos" class="text-danger"></span>
        </div>
    </div>

    <div class="mb-3">
        <label asp-for="CorreoInstitucional" class="form-label"></label>
        <input asp-for="CorreoInstitucional" class="form-control" placeholder="usuario@utn.edu.ec" />
        <span asp-validation-for="CorreoInstitucional" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="CarreraId" class="form-label">Carrera</label>
        <select asp-for="CarreraId" class="form-select" aria-label="Seleccione su carrera">
            <option value="">Seleccione...</option>
            @foreach (var carrera in Model.Carreras)
            {
                <option value="@carrera.CarreraId">@carrera.Nombre</option>
            }
        </select>
        <span asp-validation-for="CarreraId" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-6 mb-3">
            <label asp-for="Contrasena" class="form-label"></label>
            <input asp-for="Contrasena" type="password" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="Contrasena" class="text-danger"></span>
        </div>
        <div class="col-6 mb-3">
            <label asp-for="ConfirmarContrasena" class="form-label"></label>
            <input asp-for="ConfirmarContrasena" type="password" class="form-control" placeholder="••••••••" />
            <span asp-validation-for="ConfirmarContrasena" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn sb-btn-solid w-100">Crear cuenta</button>
    <p class="text-center mt-3">
        ¿Ya tienes cuenta? <a asp-controller="Account" asp-action="Login" class="sb-link-green">Iniciar sesión</a>
    </p>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function esCedulaEcuatorianaValida(cedula) {
            if (!/^[0-9]{10}$/.test(cedula)) return false;

            const provincia = parseInt(cedula.substring(0, 2), 10);
            if ((provincia < 1 || provincia > 24) && provincia !== 30) return false;

            const tercerDigito = parseInt(cedula[2], 10);
            if (tercerDigito >= 6) return false;

            const coeficientes = [2, 1, 2, 1, 2, 1, 2, 1, 2];
            let suma = 0;

            for (let i = 0; i < 9; i++) {
                let producto = parseInt(cedula[i], 10) * coeficientes[i];
                if (producto >= 10) producto -= 9;
                suma += producto;
            }

            const residuo = suma % 10;
            const digitoVerificadorEsperado = (residuo === 0) ? 0 : (10 - residuo);
            const digitoVerificadorIngresado = parseInt(cedula[9], 10);

            return digitoVerificadorEsperado === digitoVerificadorIngresado;
        }

        const inputCedula = document.getElementById('Cedula');
        const feedbackCedula = document.getElementById('cedulaFeedback');

        if (inputCedula) {
            inputCedula.addEventListener('input', function () {
                // Filtrar solo números y limitar a 10 dígitos
                this.value = this.value.replace(/[^0-9]/g, '').slice(0, 10);

                if (this.value.length === 10) {
                    if (esCedulaEcuatorianaValida(this.value)) {
                        this.classList.remove('is-invalid');
                        this.classList.add('is-valid');
                        if (feedbackCedula) feedbackCedula.textContent = '';
                    } else {
                        this.classList.remove('is-valid');
                        this.classList.add('is-invalid');
                        // Mensaje aplicando leyes de UX: Claro, constructivo y libre de culpabilidad
                        if (feedbackCedula) {
                            feedbackCedula.textContent = 'La cédula ingresada no es válida. Revisa los 10 dígitos e inténtalo de nuevo.';
                        }
                    }
                } else {
                    // Si aún no completa los 10 dígitos, no mostramos error agresivo
                    this.classList.remove('is-valid', 'is-invalid');
                    if (feedbackCedula) feedbackCedula.textContent = '';
                }
            });
        }

        // Nombres y apellidos: bloqueo de números/símbolos
        ['Nombres', 'Apellidos'].forEach(function (id) {
            const input = document.getElementById(id);
            if (input) {
                input.addEventListener('input', function () {
                    this.value = this.value.replace(/[^A-Za-zÁÉÍÓÚáéíóúÑñÜü ]/g, '');
                });
            }
        });
    </script>
}